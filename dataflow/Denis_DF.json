{
	"name": "Denis_DF",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Category_S",
						"type": "DatasetReference"
					},
					"name": "CategoryData"
				},
				{
					"dataset": {
						"referenceName": "SubCategory_S",
						"type": "DatasetReference"
					},
					"name": "SubCategoryData"
				},
				{
					"dataset": {
						"referenceName": "Product_S",
						"type": "DatasetReference"
					},
					"name": "ProductData"
				},
				{
					"dataset": {
						"referenceName": "SalesRep_S",
						"type": "DatasetReference"
					},
					"name": "SalesRepData"
				},
				{
					"dataset": {
						"referenceName": "Sales_S",
						"type": "DatasetReference"
					},
					"name": "SalesData"
				},
				{
					"dataset": {
						"referenceName": "Geography_S",
						"type": "DatasetReference"
					},
					"name": "GeographyData"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "CategorySubCatJoin"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Column_1 as string,",
				"          Column_2 as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> CategoryData",
				"source(output(",
				"          SubCategoryKey as short,",
				"          CategoryKey as short,",
				"          {SubCategory Name} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SubCategoryData",
				"source(output(",
				"          ProductID as short,",
				"          SubCategoryKey as short,",
				"          Color as string,",
				"          ProductName as string,",
				"          RetailPrice as double,",
				"          StandardCost as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> ProductData",
				"source(output(",
				"          SalesRepID as short,",
				"          SalesRepName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SalesRepData",
				"source(output(",
				"          fSalesPrimaryKey as integer,",
				"          ProductID as short,",
				"          SalesRepID as short,",
				"          Country as string,",
				"          Town as string,",
				"          Date as date,",
				"          Units as short,",
				"          PercentOfStandardCost as double,",
				"          RevenueDiscount as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SalesData",
				"source(output(",
				"          GeoKey as short,",
				"          Country as string,",
				"          Town as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> GeographyData",
				"CategoryData, SubCategoryData join(Column_2 == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> CategorySubCatJoin"
			]
		}
	}
}