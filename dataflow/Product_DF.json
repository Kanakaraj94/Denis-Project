{
	"name": "Product_DF",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Product_B",
						"type": "DatasetReference"
					},
					"name": "ProductBronze"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Product_S",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "RowNumber"
				},
				{
					"name": "filterUniqueID"
				},
				{
					"name": "selectedClms"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ProductID as short,",
				"          {Sub Category Key} as short,",
				"          Color as string,",
				"          ProductName as string,",
				"          RetailPrice as double,",
				"          StandardCost as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> ProductBronze",
				"ProductBronze window(over(ProductID),",
				"     asc(ProductID, true),",
				"     RowNum = rowNumber()) ~> RowNumber",
				"RowNumber filter(RowNum == 1) ~> filterUniqueID",
				"filterUniqueID select(mapColumn(",
				"          ProductID,",
				"          SubCategoryKey = {Sub Category Key},",
				"          Color,",
				"          ProductName,",
				"          RetailPrice,",
				"          StandardCost",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectedClms",
				"selectedClms sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     filePattern:'Product_S',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink2"
			]
		}
	}
}