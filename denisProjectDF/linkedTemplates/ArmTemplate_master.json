{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "denisProjectDF"
		},
		"Adls2Adf_ls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Adls2Adf_ls'"
		},
		"Adf2AzSQL_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "dbdenis.database.windows.net"
		},
		"Adf2AzSQL_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "denis_db"
		},
		"Adf2AzSQL_ls_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "denis_admin"
		},
		"Adls2Adf_ls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsstoragedenis.dfs.core.windows.net/"
		},
		"AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://KVdenis.vault.azure.net/"
		},
		"Blob2Adf_ls_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "blobConnString"
		},
		"Mongo2Adf_ls_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "mongoConnString"
		},
		"Mongo2Adf_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "denis_db"
		},
		"MySql2Adf_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost"
		},
		"MySql2Adf_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "denis_db"
		},
		"MySql2Adf_ls_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "root"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "denisProjectDF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Adls2Adf_ls_accountKey": {
						"value": "[parameters('Adls2Adf_ls_accountKey')]"
					},
					"Adls2Adf_ls_properties_typeProperties_url": {
						"value": "[parameters('Adls2Adf_ls_properties_typeProperties_url')]"
					},
					"AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"Adf2AzSQL_ls_properties_typeProperties_server": {
						"value": "[parameters('Adf2AzSQL_ls_properties_typeProperties_server')]"
					},
					"Adf2AzSQL_ls_properties_typeProperties_database": {
						"value": "[parameters('Adf2AzSQL_ls_properties_typeProperties_database')]"
					},
					"Adf2AzSQL_ls_properties_typeProperties_userName": {
						"value": "[parameters('Adf2AzSQL_ls_properties_typeProperties_userName')]"
					},
					"Blob2Adf_ls_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('Blob2Adf_ls_properties_typeProperties_connectionString_secretName')]"
					},
					"Mongo2Adf_ls_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('Mongo2Adf_ls_properties_typeProperties_connectionString_secretName')]"
					},
					"Mongo2Adf_ls_properties_typeProperties_database": {
						"value": "[parameters('Mongo2Adf_ls_properties_typeProperties_database')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "denisProjectDF_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"MySql2Adf_ls_properties_typeProperties_server": {
						"value": "[parameters('MySql2Adf_ls_properties_typeProperties_server')]"
					},
					"MySql2Adf_ls_properties_typeProperties_database": {
						"value": "[parameters('MySql2Adf_ls_properties_typeProperties_database')]"
					},
					"MySql2Adf_ls_properties_typeProperties_username": {
						"value": "[parameters('MySql2Adf_ls_properties_typeProperties_username')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'denisProjectDF_ArmTemplate_0')]"
			]
		}
	]
}